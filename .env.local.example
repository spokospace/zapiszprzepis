# Wymagane env vars walidowane przy module load w src/lib/env.ts (server-only).
# Brak którejkolwiek = throw "Missing required env: <NAME>" przy starcie.
#
# Supabase project — skopiuj do .env.local i uzupełnij wartościami z dashboardu
# (Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Bazowy URL aplikacji — w dev: http://localhost:3000
# Na Vercel: ustaw per środowisko (Production + Preview); fallback w runtime na request origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Trigger.dev (F-01 async job runner) — uzyskaj klucze z dashboardu projektu
# (https://cloud.trigger.dev → Project → API Keys).
# TRIGGER_SECRET_KEY: dev key dla local (tr_dev_*); production key wpisz w Cloudflare
# Workers Variables and Secrets (jako Secret, nie Build var).
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx
