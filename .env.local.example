# Supabase project — skopiuj do .env.local i uzupełnij wartościami z dashboardu
# (Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Bazowy URL aplikacji — w dev: http://localhost:3000
# Na Vercel: ustaw per środowisko (Production + Preview); fallback w runtime na request origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Kod zaproszenia wymagany do rejestracji nowego konta (S-07).
# Ustaw realną wartość w .env.local oraz jako sekret Cloudflare Workers
# (wrangler secret put INVITE_CODE). Bez niego rejestracja rzuca błąd.
INVITE_CODE=replace-with-a-secret-invite-code

# Exa API key — wymagany do wyszukiwania przepisów przez Exa (S-09).
# Pobierz z dashboard.exa.ai → API Keys.
EXA_API_KEY=replace-with-your-exa-api-key
